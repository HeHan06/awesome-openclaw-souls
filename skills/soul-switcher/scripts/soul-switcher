#!/bin/bash
# 🎭 Soul Switcher CLI - 百变龙虾主控脚本
# 支持命令：启用、切换、预览、关闭

set -e

# 配置路径
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REFERENCE_DIR="$SCRIPT_DIR/../reference"
CONFIG_FILE="$REFERENCE_DIR/config.yaml"
SOULS_DIR="$REFERENCE_DIR/souls"
OPENCLAW_CONFIG_DIR="${HOME}/.openclaw"
SOUL_TARGET="${HOME}/.openclaw/workspace/SOUL.md"
LOG_FILE="$OPENCLAW_CONFIG_DIR/soul-switcher.log"
CRON_JOB_NAME="百变龙虾-每日切换"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# 日志函数
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

# 打印带颜色的消息
print_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
print_success() { echo -e "${GREEN}✅ $1${NC}"; }
print_error() { echo -e "${RED}❌ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
print_highlight() { echo -e "${CYAN}$1${NC}"; }

# ═══════════════════════════════════════════════════════════════
# OpenClaw cron 工具函数
# ═══════════════════════════════════════════════════════════════

# 检查 openclaw cron 是否可用
has_openclaw_cron() {
    command -v openclaw &>/dev/null
}

# 获取百变龙虾 cron job ID（通过名称匹配）
get_cron_job_id() {
    if ! has_openclaw_cron; then return 1; fi
    openclaw cron list --json 2>/dev/null | \
        python3 -c "
import json,sys
data=json.load(sys.stdin)
jobs=data.get('jobs',[])
name='${CRON_JOB_NAME}'
ids=[j['id'] for j in jobs if j.get('name')==name]
print(ids[0] if ids else '')
" 2>/dev/null || true
}

# 检查 openclaw cron 是否已启用百变龙虾
is_openclaw_cron_enabled() {
    local job_id
    job_id=$(get_cron_job_id)
    [[ -n "$job_id" ]]
}

# 添加 openclaw cron job（每天 10:15 Asia/Shanghai）
add_openclaw_cron() {
    openclaw cron add \
        --name "$CRON_JOB_NAME" \
        --cron "15 10 * * *" \
        --tz "Asia/Shanghai" \
        --session isolated \
        --message "执行百变龙虾每日 Soul 切换。请运行：bash ~/.openclaw/skills/soul-switcher/scripts/switch-soul.sh 然后用新的 Soul 风格向用户问好。" \
        --announce \
        2>&1
}

# 移除 openclaw cron job
remove_openclaw_cron() {
    local job_id
    job_id=$(get_cron_job_id)
    if [[ -n "$job_id" ]]; then
        openclaw cron remove "$job_id" 2>&1
        return $?
    fi
    return 1
}

# ═══════════════════════════════════════════════════════════════
# 核心功能函数
# ═══════════════════════════════════════════════════════════════

# 获取 Soul 数量
get_souls_count() {
    ls -1 "$SOULS_DIR"/*.md 2>/dev/null | wc -l
}

# 从配置文件获取 Soul 信息
get_soul_info_from_config() {
    local field="$1"
    local index="$2"

    if command -v yq &> /dev/null; then
        yq eval ".souls_pool[$index].$field" "$CONFIG_FILE" 2>/dev/null | tr -d '"'
    else
        awk -v idx="$index" -v fld="$field" '
            BEGIN { count = -1 }
            /^  - name:/ { count++ }
            count == idx {
                if (fld == "name") {
                    line = $0
                    start = index(line, "\"")
                    if (start > 0) {
                        rest = substr(line, start + 1)
                        end = index(rest, "\"")
                        if (end > 0) { print substr(rest, 1, end - 1); exit }
                    }
                } else {
                    prefix = "    " fld ": "
                    if (index($0, prefix) == 1) {
                        value = substr($0, length(prefix) + 1)
                        if (substr(value, 1, 1) == "\"") value = substr(value, 2)
                        if (substr(value, length(value), 1) == "\"") value = substr(value, 1, length(value) - 1)
                        print value; exit
                    }
                }
            }
        ' "$CONFIG_FILE"
    fi
}

get_current_soul_index() {
    if [[ -f "$REFERENCE_DIR/.current_soul" ]]; then
        cat "$REFERENCE_DIR/.current_soul"
    else
        echo "0"
    fi
}

set_current_soul_index() {
    echo "$1" > "$REFERENCE_DIR/.current_soul"
}

get_soul_file_by_index() {
    local index="$1"
    local file
    file=$(get_soul_info_from_config "file" "$index")
    echo "$SOULS_DIR/$(basename "$file")"
}

get_soul_name() { get_soul_info_from_config "name" "$1"; }
get_soul_icon() { get_soul_info_from_config "icon" "$1"; }
get_soul_description() { get_soul_info_from_config "description" "$1"; }

send_greeting() {
    local index="$1"
    local soul_name soul_icon
    soul_name=$(get_soul_name "$index")
    soul_icon=$(get_soul_icon "$index")
    local greeting_file="$REFERENCE_DIR/greetings/$(echo "$soul_name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')-greeting.md"
    
    echo ""
    echo "═══════════════════════════════════════════════════"
    echo "  🎭 百变龙虾 - Soul 切换成功"
    echo "═══════════════════════════════════════════════════"
    echo ""
    echo -e "${MAGENTA}当前人格: $soul_icon $soul_name ${NC}"
    echo ""
    
    if [[ -f "$greeting_file" ]]; then
        cat "$greeting_file"
    else
        generate_default_greeting "$index"
    fi
    
    echo ""
    echo "═══════════════════════════════════════════════════"
}

generate_default_greeting() {
    local index="$1"
    local soul_name soul_desc
    soul_name=$(get_soul_name "$index")
    soul_desc=$(get_soul_description "$index")
    cat << EOF
🌟 你好！我是 **$soul_name**

$soul_desc

今天我会以我的风格陪伴你，有什么需要尽管告诉我！✨
EOF
}

# 执行 Soul 切换（写入 workspace/SOUL.md）
do_switch_soul() {
    local index="$1"
    local soul_file soul_name
    soul_file=$(get_soul_file_by_index "$index")
    soul_name=$(get_soul_name "$index")
    
    if [[ ! -f "$soul_file" ]]; then
        print_error "Soul 文件不存在: $soul_file"
        return 1
    fi
    
    mkdir -p "$(dirname "$SOUL_TARGET")"
    
    # 备份当前 Soul
    if [[ -f "$SOUL_TARGET" ]]; then
        cp "$SOUL_TARGET" "$SOUL_TARGET.backup.$(date +%Y%m%d_%H%M%S)"
    fi
    
    # 写入 workspace/SOUL.md（OpenClaw 实际读取的路径）
    cp "$soul_file" "$SOUL_TARGET"
    set_current_soul_index "$index"
    log "Soul 已切换为: $soul_name (索引: $index)"
    
    print_success "Soul 已切换为: $soul_name"
    print_info "已写入: $SOUL_TARGET"
    
    # 通知 OpenClaw 当前对话立即重读 SOUL.md（无损切换）
    if command -v openclaw &>/dev/null; then
        openclaw session send --message "【Soul 已切换】人格已更新为「$soul_name」。请立即重新读取 SOUL.md，并从现在起完全按照新人格回复，无需等待下次对话。" 2>/dev/null || true
        print_info "已通知 OpenClaw 立即切换人格（当前对话即时生效）"
        log "已通知 OpenClaw 重读 SOUL.md"
    else
        print_info "提示：openclaw 命令不可用，新 Soul 将在下次 /reset 或新对话生效"
    fi
    
    send_greeting "$index"
}

# ═══════════════════════════════════════════════════════════════
# 命令实现
# ═══════════════════════════════════════════════════════════════

cmd_enable() {
    echo ""
    echo -e "${CYAN}🎭 欢迎使用百变龙虾 (Soul Switcher)${NC}"
    echo "═══════════════════════════════════════════════════"
    echo ""
    
    if [[ ! -d "$SOULS_DIR" ]] || [[ $(get_souls_count) -eq 0 ]]; then
        print_error "souls 目录为空，请先添加 Soul 文件到 $SOULS_DIR/"
        return 1
    fi

    print_info "正在安装定时任务..."

    if has_openclaw_cron; then
        if is_openclaw_cron_enabled; then
            print_warning "百变龙虾定时任务已存在（openclaw cron），跳过重复安装"
        else
            if add_openclaw_cron; then
                print_success "定时任务已安装（openclaw cron，每天 10:15 Asia/Shanghai）"
            else
                print_warning "openclaw cron 安装失败，回退到系统 crontab..."
                _install_system_cron
            fi
        fi
    else
        print_warning "未检测到 openclaw，使用系统 crontab..."
        _install_system_cron
    fi
    
    echo ""
    print_info "正在应用今日 Soul..."
    local weekday index
    weekday=$(date +%w)
    index=$((weekday % $(get_souls_count)))
    do_switch_soul "$index"
    
    echo ""
    print_success "百变龙虾已启用！"
    echo ""
    echo -e "${YELLOW}提示:${NC}"
    echo "  • 每天 10:15 自动切换 Soul（自动通知当前对话立即生效）"
    echo "  • 使用 'soul-switcher 切换' 手动切换"
    echo "  • 使用 'soul-switcher 预览' 查看所有 Soul"
}

_install_system_cron() {
    local CRON_TAG="# soul-switcher-auto"
    local cron_job="15 10 * * * cd \"$SCRIPT_DIR\" && ./switch-soul.sh $CRON_TAG"
    (crontab -l 2>/dev/null || true) | grep -v "$CRON_TAG" > /tmp/soul-cron.tmp || true
    echo "$cron_job" >> /tmp/soul-cron.tmp
    crontab /tmp/soul-cron.tmp
    rm -f /tmp/soul-cron.tmp
    print_success "定时任务已安装（系统 crontab，每天 10:15）"
}

cmd_disable() {
    echo ""
    echo -e "${CYAN}🛑 关闭百变龙虾${NC}"
    echo "═══════════════════════════════════════════════════"
    echo ""
    
    local removed=0

    if has_openclaw_cron && is_openclaw_cron_enabled; then
        print_info "正在移除 openclaw cron 定时任务..."
        if remove_openclaw_cron; then
            print_success "openclaw cron 定时任务已移除"
            removed=1
        else
            print_warning "openclaw cron 移除失败"
        fi
    fi

    local CRON_TAG="# soul-switcher-auto"
    if crontab -l 2>/dev/null | grep -q "$CRON_TAG"; then
        print_info "正在移除系统 crontab 遗留任务..."
        (crontab -l 2>/dev/null || true) | grep -v "$CRON_TAG" > /tmp/soul-cron.tmp || true
        crontab /tmp/soul-cron.tmp
        rm -f /tmp/soul-cron.tmp
        print_success "系统 crontab 任务已移除"
        removed=1
    fi

    if [[ $removed -eq 0 ]]; then
        print_warning "百变龙虾当前未运行（未找到任何定时任务）"
        return 0
    fi
    
    echo ""
    print_info "当前 Soul 保持不变"
    echo -e "${YELLOW}提示:${NC} 百变龙虾已关闭，不再自动切换"
}

cmd_switch() {
    local direction="${1:-next}"
    echo ""
    echo -e "${CYAN}🔄 切换 Soul${NC}"
    echo "═══════════════════════════════════════════════════"
    echo ""
    
    local count
    count=$(get_souls_count)
    if [[ $count -eq 0 ]]; then
        print_error "没有找到可用的 Soul 文件"
        return 1
    fi
    
    local current next_index
    current=$(get_current_soul_index)
    
    if [[ "$direction" == "next" ]]; then
        next_index=$(((current + 1) % count))
    elif [[ "$direction" == "prev" ]]; then
        next_index=$(((current - 1 + count) % count))
    elif [[ "$direction" =~ ^[0-9]+$ ]]; then
        next_index=$direction
        if [[ $next_index -ge $count ]]; then
            print_error "索引超出范围，有效范围: 0-$((count-1))"
            return 1
        fi
    else
        next_index=""
        for i in $(seq 0 $((count-1))); do
            local name
            name=$(get_soul_name "$i")
            if [[ "$name" == *"$direction"* ]]; then
                next_index=$i
                break
            fi
        done
        if [[ -z "$next_index" ]]; then
            print_error "未知的 Soul: $direction"
            return 1
        fi
    fi
    
    do_switch_soul "$next_index"
}

cmd_preview() {
    echo ""
    echo -e "${CYAN}👁️  Soul 预览${NC}"
    echo "═══════════════════════════════════════════════════"
    echo ""
    local count current
    count=$(get_souls_count)
    current=$(get_current_soul_index)
    
    echo "📋 可用的 Soul 列表 ($count 个):"
    echo "───────────────────────────────────────────────────"
    echo ""
    
    for i in $(seq 0 $((count-1))); do
        local name icon desc marker color
        name=$(get_soul_name "$i")
        icon=$(get_soul_icon "$i")
        desc=$(get_soul_description "$i")
        marker=""
        color=""
        if [[ "$i" == "$current" ]]; then
            marker=" ← 当前"
            color="${GREEN}"
        fi
        echo -e "${color}  [$i] $icon $name${NC}$marker"
        echo "      $desc"
        echo ""
    done
    
    echo "───────────────────────────────────────────────────"
    echo -e "${YELLOW}使用方式:${NC}"
    echo "  soul-switcher 切换 [索引/名称]  - 切换到指定 Soul"
    echo "  soul-switcher 切换              - 切换到下一个"
    echo ""
}

cmd_status() {
    echo ""
    echo -e "${CYAN}📊 百变龙虾状态${NC}"
    echo "═══════════════════════════════════════════════════"
    echo ""
    
    if has_openclaw_cron && is_openclaw_cron_enabled; then
        local job_id
        job_id=$(get_cron_job_id)
        echo -e "运行状态: ${GREEN}● 已启用（openclaw cron）${NC}"
        echo "定时任务: 每天 10:15 Asia/Shanghai 自动切换（job: $job_id）"
    elif crontab -l 2>/dev/null | grep -q "soul-switcher-auto"; then
        echo -e "运行状态: ${GREEN}● 已启用（系统 crontab）${NC}"
        echo "定时任务: 每天 10:15 自动切换"
    else
        echo -e "运行状态: ${RED}● 已关闭${NC}"
        echo "定时任务: 无"
    fi
    
    echo ""
    local current name icon count
    current=$(get_current_soul_index)
    name=$(get_soul_name "$current")
    icon=$(get_soul_icon "$current")
    count=$(get_souls_count)
    
    echo -e "当前 Soul: ${MAGENTA}$icon $name${NC}"
    echo "Soul 写入: $SOUL_TARGET"
    echo "Soul 数量: $count 个"
    echo "配置路径: $CONFIG_FILE"
    echo "日志路径: $LOG_FILE"
    echo ""
}

cmd_help() {
    cat << EOF

🎭 百变龙虾 (Soul Switcher) - 使用指南
═══════════════════════════════════════════════════

${CYAN}命令列表:${NC}

  ${GREEN}启用${NC}              启动百变龙虾，安装定时任务
  ${GREEN}关闭${NC}              停止百变龙虾，移除定时任务
  ${GREEN}切换${NC} [索引/名称]   手动切换到指定 Soul
  ${GREEN}预览${NC}              查看所有可用 Soul
  ${GREEN}状态${NC}              查看当前运行状态
  ${GREEN}帮助${NC}              显示此帮助信息

${CYAN}说明:${NC}

  • 优先使用 openclaw cron（Gateway 内置调度器）
  • openclaw 不可用时自动回退到系统 crontab
  • Soul 文件写入 ~/.openclaw/workspace/SOUL.md
  • 新 Soul 在下次 /reset 或新对话时生效

═══════════════════════════════════════════════════

EOF
}

# ═══════════════════════════════════════════════════════════════
# 主函数
# ═══════════════════════════════════════════════════════════════

main() {
    mkdir -p "$OPENCLAW_CONFIG_DIR"
    case "${1:-}" in
        启用|enable|start|on) cmd_enable ;;
        关闭|disable|stop|off) cmd_disable ;;
        切换|switch|next) cmd_switch "${2:-next}" ;;
        预览|preview|list|ls) cmd_preview ;;
        状态|status|state) cmd_status ;;
        帮助|help|-h|--help) cmd_help ;;
        *) cmd_help ;;
    esac
}

main "$@"
